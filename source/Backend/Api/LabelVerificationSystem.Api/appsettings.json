{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=label-verification.db"
  },
  "ExcelUploadStorage": {
    "RootFolder": "App_Data/excel-uploads"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "LabelVerificationSystem.Api",
      "Audience": "LabelVerificationSystem.Web",
      "SigningKey": "ChangeMe-LocalDev-Only-AtLeast-32-Characters",
      "AccessTokenTtlMinutes": 20,
      "RefreshProactiveWindowMinutes": 3,
      "ClockSkewSeconds": 60
    },
    "RefreshToken": {
      "TtlMinutes": 1440
    },
    "PasswordReset": {
      "TokenTtlMinutes": 30,
      "RevokeAllSessionsOnPasswordReset": true
    },
    "Bypass": {
      "Enabled": false,
      "AllowedEnvironments": [
        "Development"
      ],
      "UserId": "bypass-system",
      "Username": "system-bypass",
      "DisplayName": "System Bypass",
      "Email": null,
      "Roles": [
        "SuperAdmin",
        "Administrator"
      ],
      "Permissions": [
        "excel.upload.create",
        "users.read",
        "users.manage"
      ]
    },
    "ConfiguredUsersRobustBridge": {
      "Enabled": false,
      "AllowedEnvironments": [
        "Development"
      ]
    },
    "Users": [
      {
        "UserId": "operator-001",
        "Username": "operator",
        "Password": "Operator123!",
        "DisplayName": "Operador Local",
        "Email": "operator@local.test",
        "IsActive": true,
        "Roles": [
          "Operator"
        ],
        "Permissions": [
          "excel.upload.create"
        ]
      },
      {
        "UserId": "admin-001",
        "Username": "admin",
        "Password": "Admin123!",
        "DisplayName": "Administrador Local",
        "Email": "admin@local.test",
        "IsActive": true,
        "Roles": [
          "SuperAdmin",
          "Administrator"
        ],
        "Permissions": [
          "excel.upload.create",
          "users.read",
          "users.manage"
        ]
      }
    ]
  },
  "Authorization": {
    "UseRobustMatrix": true,
    "EnableLegacyFallback": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
