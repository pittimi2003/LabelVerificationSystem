{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=labelverification.db"
  },
  "Authentication": {
    "PasswordReset": {
      "TokenTtlMinutes": 30,
      "RevokeAllSessionsOnPasswordReset": true
    },
    "Bypass": {
      "Enabled": false
    }
  },
  "Authorization": {
    "UseRobustMatrix": true,
    "EnableLegacyFallback": true
  }
}
