@page "/excel-uploads"
@using LabelVerificationSystem.Web.Components.ExcelUploads
@inject ExcelUploadApiClient ExcelUploadApiClient
@inject ISnackbar Snackbar

<PageTitle>Carga de Excel</PageTitle>

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
            <MudText Typo="Typo.h5">Carga de Excel</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@IsLoading" OnClick="LoadHistoryAsync" StartIcon="@Icons.Material.Filled.Refresh">
                Actualizar historial
            </MudButton>
        </MudStack>

        <MudText Typo="Typo.h6" Class="mb-2">Subir archivo Excel</MudText>

        <MudFileUpload T="IBrowserFile"
                       @key="@FileUploadResetKey"
                       FilesChanged="OnFileSelected"
                       Accept=".xlsx,.xls"
                       Disabled="@IsLoading"
                       Hidden="true"
                       InputClass="d-none">
            <ActivatorContent>
                <MudPaper Class="@DropzoneClass" Outlined="true" Width="100%">
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="1" Class="py-6 px-4">
                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Arrastra el archivo aquí</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Formatos permitidos: .xlsx, .xls</MudChip>
                    </MudStack>
                </MudPaper>
            </ActivatorContent>
        </MudFileUpload>

        @if (SelectedFile is not null)
        {
            <MudPaper Class="pa-3" Outlined="true">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Info" />
                            <MudText Typo="Typo.body1">@SelectedFile.Name</MudText>
                        </MudStack>
                        <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">Listo para cargar</MudChip>
                    </MudStack>

                    <MudText Typo="Typo.body2" Color="Color.Default">Tamaño: @GetHumanReadableFileSize(SelectedFile.Size)</MudText>

                    <MudStack Row="true" Spacing="2" Justify="Justify.Center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@IsLoading" OnClick="UploadAsync" StartIcon="@Icons.Material.Filled.CloudUpload">Cargar</MudButton>
                        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" Disabled="@IsLoading" OnClick="ClearSelectedFile">Quitar archivo</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }



        @if (IsLoading)
        {
            <div class="d-flex align-center gap-2 mt-1">
                <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
                <MudText Typo="Typo.body2">Procesando carga...</MudText>
            </div>
        }

        <MudDivider />

        <MudText Typo="Typo.h6" Class="mb-2">Historial de cargas</MudText>

        @if (IsHistoryLoading)
        {
            <div class="d-flex align-center gap-2">
                <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
                <MudText Typo="Typo.body2">Cargando historial...</MudText>
            </div>
        }
        else if (HistoryItems.Count == 0)
        {
            <MudText Typo="Typo.body2">No hay cargas registradas todavía.</MudText>
        }
        else
        {
            <MudTable Dense="true" Hover="true" Elevation="0" Items="@HistoryItems" Class="admin-grid-table">
                <HeaderContent>
                    <MudTh>Acción</MudTh>
                    <MudTh>UploadId</MudTh>
                    <MudTh>Archivo</MudTh>
                    <MudTh>Fecha UTC</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Total</MudTh>
                    <MudTh>Insertadas</MudTh>
                    <MudTh>Rechazadas</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudTooltip Text="Ver detalle">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary" OnClick="() => OpenDetailAsync(context.UploadId)" />
                        </MudTooltip>
                    </MudTd>
                    <MudTd>@context.UploadId</MudTd>
                    <MudTd>@context.OriginalFileName</MudTd>
                    <MudTd>@context.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@(context.RejectedRows > 0 ? Color.Warning : Color.Success)" Variant="Variant.Outlined">@context.Status</MudChip>
                    </MudTd>
                    <MudTd>@context.TotalRows</MudTd>
                    <MudTd>@context.InsertedRows</MudTd>
                    <MudTd>@context.RejectedRows</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudStack>
</MudPaper>

<MudDrawer Anchor="Anchor.End" Variant="DrawerVariant.Temporary" Open="@IsDetailDrawerOpen" Width="680px" Elevation="6">
    <MudDrawerHeader class="d-flex align-center justify-space-between border-b px-4 py-3">
        <MudText Typo="Typo.h6">Detalle de carga Excel</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseDetailDrawer" />
    </MudDrawerHeader>

    <MudStack Class="pa-4" Spacing="2">
        @if (IsDetailLoading)
        {
            <div class="d-flex align-center gap-2">
                <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
                <MudText Typo="Typo.body2">Cargando detalle...</MudText>
            </div>
        }
        else if (SelectedDetail is null)
        {
            <MudText Typo="Typo.body2">No hay detalle para mostrar.</MudText>
        }
        else
        {
            <MudStack Spacing="2">
                <MudPaper Outlined="true" Class="pa-3">
                    <MudText Typo="Typo.h6">Resumen</MudText>
                    <MudDivider Class="my-2" />
                    <MudGrid Class="mt-2">
                        <MudItem xs="12" sm="6">
                            <MudCard Class="custom-card mb-0 dashboard-main-card overflow-hidden primary h-100">
                                <MudCardContent>
                                    <span class="fs-13 fw-medium">Archivo</span>
                                    <MudText Typo="Typo.h6" Class="fw-semibold my-2 lh-1">
                                        @SelectedDetail.OriginalFileName
                                    </MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudCard Class="custom-card mb-0 dashboard-main-card overflow-hidden primary h-100">
                                <MudCardContent>
                                    <span class="fs-13 fw-medium">Fecha UTC</span>
                                    <MudText Typo="Typo.h6" Class="fw-semibold my-2 lh-1">
                                        @SelectedDetail.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")
                                    </MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="6" sm="6">
                            <MudCard Class="custom-card mb-0 dashboard-main-card overflow-hidden primary h-100">
                                <MudCardContent>
                                    <span class="fs-13 fw-medium">Estado</span>
                                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">
                                        @SelectedDetail.Status
                                    </MudChip>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>                        
                    </MudGrid>
                </MudPaper>

                <MudTabs Elevation="0" Rounded="true" PanelClass="pt-3" ActivePanelIndex="@DetailTabIndex" ActivePanelIndexChanged="OnDetailTabIndexChanged">
                    <MudTabPanel Text="Vista General" />
                    <MudTabPanel Text="Vista por fila" />
                </MudTabs>

                @if (DetailViewMode == "general")
                {
                    <MudStack Spacing="2">
                        <MudPaper Outlined="true" Class="pa-3">
                            <MudText Typo="Typo.h6">Vista general</MudText>
                            <MudDivider Class="my-2" />
                            <MudGrid Class="mt-2">
                                <MudItem xs="12" sm="6">
                                    <MudCard Class="custom-card mb-0 dashboard-main-card overflow-hidden primary h-100">
                                        <MudCardContent>
                                            <span class="fs-13 fw-medium">Total filas</span>
                                            <MudText Typo="Typo.h6" Class="fw-semibold my-2 lh-1">
                                                @SelectedDetail.TotalRows
                                            </MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudCard Class="custom-card mb-0 dashboard-main-card overflow-hidden primary h-100">
                                        <MudCardContent>
                                            <span class="fs-13 fw-medium">Insertadas</span>
                                            <MudText Typo="Typo.h6" Class="fw-semibold my-2 lh-1">
                                                @SelectedDetail.InsertedRows
                                            </MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudCard Class="custom-card mb-0 dashboard-main-card overflow-hidden primary h-100">
                                        <MudCardContent>
                                            <span class="fs-13 fw-medium">Rechazadas</span>
                                            <MudText Typo="Typo.h6" Class="fw-semibold my-2 lh-1">
                                                @SelectedDetail.RejectedRows
                                            </MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudCard Class="custom-card mb-0 dashboard-main-card overflow-hidden primary h-100">
                                        <MudCardContent>
                                            <span class="fs-13 fw-medium">% éxito</span>
                                            <MudText Typo="Typo.h6" Class="fw-semibold my-2 text-success">
                                                100.0%
                                            </MudText>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>

                        <MudPaper Class="pa-3" Outlined="true">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Warning" />
                                    <MudText Typo="Typo.h6">Agrupación por ErrorCode</MudText>
                                </MudStack>
                                <MudDivider Class="my-2" />
                                @if (ErrorGroups.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined">
                                        Esta carga no registró errores por fila.
                                    </MudAlert>
                                }
                                else
                                {
                                    <MudTable Dense="true" Hover="true" Elevation="0" Items="@ErrorGroups" Class="admin-grid-table">
                                        <HeaderContent>
                                            <MudTh>Error code</MudTh>
                                            <MudTh>Mensaje</MudTh>
                                            <MudTh>Cantidad</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">@context.ErrorCode</MudChip>
                                            </MudTd>
                                            <MudTd>@context.ErrorMessage</MudTd>
                                            <MudTd><MudChip T="int" Size="Size.Small" Color="Color.Warning">@context.Count</MudChip></MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                        </MudPaper>
                    </MudStack>
                }
                else
                {
                    <MudPaper Class="pa-3" Outlined="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">
                            <MudText Typo="Typo.h6">Detalle por fila</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="ClearRowFilters">
                                Limpiar filtros
                            </MudButton>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        <MudGrid Class="mb-1">
                            <MudItem xs="12" sm="4">
                                <MudSelect T="string"
                                           Label="Campo"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Value="@SelectedSearchField"
                                           ValueChanged="OnSelectedSearchFieldChanged">
                                    @foreach (var option in SearchFieldOptions)
                                    {
                                        <MudSelectItem Value="@option.Value">@option.Label</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="8">
                                <MudTextField T="string"
                                              Label="@($"Buscar por {SelectedSearchFieldLabel}")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Value="@SearchTextFilter"
                                              ValueChanged="OnSearchTextFilterChanged"
                                              Immediate="true"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Search" />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudSelect T="string"
                                           Label="Filtrar por Status"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Value="@StatusFilter"
                                           ValueChanged="OnStatusFilterChanged">
                                    <MudSelectItem Value="@AnyStatusValue">Todos</MudSelectItem>
                                    @foreach (var status in RowStatusOptions)
                                    {
                                        <MudSelectItem Value="@status">@status</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="8" Class="d-flex align-center">
                                <MudText Typo="Typo.caption" Class="mt-2">
                                    Mostrando <b>@FilteredRows.Count</b> de <b>@SelectedDetail.Rows.Count</b> filas.
                                </MudText>
                            </MudItem>
                        </MudGrid>

                        <MudTable @key="_rowTableRenderKey"
                                  Class="admin-grid-table"
                                  @ref="_rowDetailTable"
                                  Dense="true"
                                  Hover="true"
                                  Elevation="0"
                                  Items="@FilteredRows"
                                  RowsPerPage="@RowsPerPage"
                                  RowsPerPageChanged="OnRowsPerPageChanged">
                            <HeaderContent>
                                <MudTh>Row</MudTh>
                                <MudTh>Part Number</MudTh>
                                <MudTh>Model</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Error code</MudTh>
                                <MudTh>Error message</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.RowNumber</MudTd>
                                <MudTd>@(string.IsNullOrWhiteSpace(context.PartNumber) ? "-" : context.PartNumber)</MudTd>
                                <MudTd>@(string.IsNullOrWhiteSpace(context.Model) ? "-" : context.Model)</MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="@GetStatusVariant(context.Status)" Class="status-chip">
                                        @context.Status
                                    </MudChip>
                                </MudTd>
                                <MudTd>@(string.IsNullOrWhiteSpace(context.ErrorCode) ? "-" : context.ErrorCode)</MudTd>
                                <MudTd>@(string.IsNullOrWhiteSpace(context.ErrorMessage) ? "-" : context.ErrorMessage)</MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager RowsPerPageString="Filas por página"
                                               InfoFormat="{first_item}-{last_item} de {all_items}"
                                               HidePageNumber="false"
                                               PageSizeOptions="@PageSizeOptions" />
                            </PagerContent>
                        </MudTable>
                    </MudPaper>
                }
            </MudStack>
        }
    </MudStack>
</MudDrawer>

@code {
    private IBrowserFile? SelectedFile;
    private bool IsLoading;
    private bool IsHistoryLoading;
    private int FileUploadResetKey;

    private ExcelUploadResultDto? LastResult;
    private List<ExcelUploadHistoryItemDto> HistoryItems { get; set; } = [];

    private bool IsDetailDrawerOpen;
    private bool IsDetailLoading;
    private string DetailViewMode { get; set; } = "general";
    private ExcelUploadDetailDto? SelectedDetail;
    private MudTable<ExcelUploadRowDetailDto>? _rowDetailTable;

    private const string AnyStatusValue = "__ALL__";
    private const string SearchFieldPartNumber = "part-number";
    private const string SearchFieldModel = "model";
    private readonly IReadOnlyList<(string Label, string Value)> SearchFieldOptions =
    [
        ("Part Number", SearchFieldPartNumber),
        ("Model", SearchFieldModel)
    ];

    private readonly IReadOnlyList<string> RowStatusOptions = ["Inserted", "Rejected"];
    private string SelectedSearchField { get; set; } = SearchFieldPartNumber;
    private string SearchTextFilter { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = AnyStatusValue;
    private int RowsPerPage { get; set; } = 5;
    private readonly int[] PageSizeOptions = [5, 10, 20];
    private List<ExcelUploadRowDetailDto> _filteredRows = [];
    private int _rowTableRenderKey;

    private IReadOnlyList<(string Label, string Value)> SummaryRows => LastResult is null
        ? []
        :
        [
            ("UploadId", LastResult.UploadId.ToString()),
            ("Archivo", LastResult.FileName),
            ("Total filas", LastResult.TotalRows.ToString()),
            ("Insertadas", LastResult.InsertedRows.ToString()),
            ("Rechazadas", LastResult.RejectedRows.ToString())
        ];

    private string DropzoneClass => SelectedFile is null
        ? "excel-upload-dropzone"
        : "excel-upload-dropzone excel-upload-dropzone-selected";

    private IReadOnlyList<ErrorGroupVm> ErrorGroups => SelectedDetail?.Rows
        .Where(r => !string.IsNullOrWhiteSpace(r.ErrorCode) || !string.IsNullOrWhiteSpace(r.ErrorMessage))
        .GroupBy(r => new
        {
            Code = string.IsNullOrWhiteSpace(r.ErrorCode) ? "Unknown" : r.ErrorCode,
            Message = string.IsNullOrWhiteSpace(r.ErrorMessage) ? "Sin detalle" : r.ErrorMessage
        })
        .Select(group => new ErrorGroupVm(group.Key.Code!, group.Key.Message!, group.Count()))
        .OrderByDescending(x => x.Count)
        .ThenBy(x => x.ErrorCode)
        .ToList() ?? [];

    private string SuccessRate => SelectedDetail is null || SelectedDetail.TotalRows == 0
        ? "0.0"
        : ((double)SelectedDetail.InsertedRows / SelectedDetail.TotalRows * 100).ToString("0.0");

    private IReadOnlyList<ExcelUploadRowDetailDto> FilteredRows => _filteredRows;

    private string SelectedSearchFieldLabel => SearchFieldOptions
        .FirstOrDefault(option => option.Value == SelectedSearchField).Label ?? "Part Number";

    protected override async Task OnInitializedAsync()
    {
        Snackbar.Clear();
        await LoadHistoryAsync();
    }

    private void OnFileSelected(IBrowserFile? file)
    {
        SelectedFile = file;
    }

    private void ClearSelectedFile()
    {
        SelectedFile = null;
        FileUploadResetKey++;
    }

    private async Task UploadAsync()
    {
        if (SelectedFile is null)
        {
            Notify("Selecciona un archivo antes de cargar.", Severity.Warning);
            return;
        }

        IsLoading = true;

        try
        {
            LastResult = await ExcelUploadApiClient.UploadAsync(SelectedFile, CancellationToken.None);
            Notify("Carga completada correctamente.", Severity.Success);

            SelectedFile = null;
            FileUploadResetKey++;

            await LoadHistoryAsync();
        }
        catch (Exception ex)
        {
            Notify(ex.Message, Severity.Error);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadHistoryAsync()
    {
        Snackbar.Clear();
        IsHistoryLoading = true;

        try
        {
            HistoryItems = (await ExcelUploadApiClient.GetHistoryAsync(CancellationToken.None)).ToList();
        }
        catch (Exception ex)
        {
            HistoryItems = [];
            Notify($"No se pudo cargar el historial: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsHistoryLoading = false;
        }
    }

    private async Task OpenDetailAsync(Guid uploadId)
    {
        IsDetailDrawerOpen = true;
        IsDetailLoading = true;
        DetailViewMode = "general";
        DetailTabIndex = 0;
        SelectedDetail = null;
        ClearRowFilters();

        try
        {
            SelectedDetail = await ExcelUploadApiClient.GetDetailAsync(uploadId, CancellationToken.None);
            RecomputeFilteredRows(resetPagination: true);

            if (SelectedDetail is null)
            {
                Notify("No se encontró el detalle de la carga seleccionada.", Severity.Warning);
                IsDetailDrawerOpen = false;
            }
        }
        catch (Exception ex)
        {
            Notify($"No se pudo cargar el detalle: {ex.Message}", Severity.Error);
            IsDetailDrawerOpen = false;
        }
        finally
        {
            IsDetailLoading = false;
        }
    }

    private void CloseDetailDrawer()
    {
        IsDetailDrawerOpen = false;
    }

    private void Notify(string message, Severity severity)
    {
        Snackbar.Clear();
        Snackbar.Add(message, severity);
    }

    private int DetailTabIndex { get; set; }

    private void OnDetailTabIndexChanged(int index)
    {
        DetailTabIndex = index;
        DetailViewMode = index == 0 ? "general" : "rows";
    }

    private void OnSelectedSearchFieldChanged(string? value)
    {
        SelectedSearchField = string.IsNullOrWhiteSpace(value) ? SearchFieldPartNumber : value;
        RecomputeFilteredRows(resetPagination: true);
    }

    private void OnSearchTextFilterChanged(string? value)
    {
        SearchTextFilter = value ?? string.Empty;
        RecomputeFilteredRows(resetPagination: true);
    }

    private void OnStatusFilterChanged(string? value)
    {
        StatusFilter = string.IsNullOrWhiteSpace(value) ? AnyStatusValue : value;
        RecomputeFilteredRows(resetPagination: true);
    }

    private void OnRowsPerPageChanged(int value)
    {
        RowsPerPage = value;
        RecomputeFilteredRows(resetPagination: true);
    }

    private void ClearRowFilters()
    {
        SelectedSearchField = SearchFieldPartNumber;
        SearchTextFilter = string.Empty;
        StatusFilter = AnyStatusValue;
        RowsPerPage = 5;
        RecomputeFilteredRows(resetPagination: true);
    }

    private void RecomputeFilteredRows(bool resetPagination)
    {
        _filteredRows = SelectedDetail?.Rows
            .Where(MatchesRowFilters)
            .ToList() ?? [];

        if (!resetPagination)
        {
            return;
        }

        _rowTableRenderKey++;
        _rowDetailTable?.NavigateTo(0);
    }

    private bool MatchesRowFilters(ExcelUploadRowDetailDto row)
    {
        var matchesSearch = MatchesSearchFilter(row);
        var matchesStatus = MatchesStatusFilter(row);

        return matchesSearch && matchesStatus;
    }

    private bool MatchesSearchFilter(ExcelUploadRowDetailDto row)
    {
        var normalizedSearchText = SearchTextFilter.Trim();
        if (string.IsNullOrWhiteSpace(normalizedSearchText))
        {
            return true;
        }

        return SelectedSearchField switch
        {
            SearchFieldModel => row.Model?.Contains(normalizedSearchText, StringComparison.OrdinalIgnoreCase) is true,
            _ => row.PartNumber?.Contains(normalizedSearchText, StringComparison.OrdinalIgnoreCase) is true
        };
    }

    private bool MatchesStatusFilter(ExcelUploadRowDetailDto row)
    {
        var normalizedStatusFilter = NormalizeStatusFilter(StatusFilter);
        if (string.Equals(normalizedStatusFilter, AnyStatusValue, StringComparison.Ordinal))
        {
            return true;
        }

        return string.Equals(NormalizeStatus(row.Status), normalizedStatusFilter, StringComparison.OrdinalIgnoreCase);
    }

    private static Color GetStatusColor(string? status)
    {
        if (string.Equals(status, "Inserted", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Success;
        }

        if (string.Equals(status, "Rejected", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Error;
        }

        if (string.Equals(status, "Warning", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Warning;
        }

        return Color.Info;
    }

    private static Variant GetStatusVariant(string? status)
        => string.Equals(status, "Inserted", StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Outlined;

    private static string NormalizeStatusFilter(string? statusFilter)
        => string.IsNullOrWhiteSpace(statusFilter) ? AnyStatusValue : statusFilter.Trim();

    private static string NormalizeStatus(string? status)
        => string.IsNullOrWhiteSpace(status) ? "Unknown" : status.Trim();

    private static string GetHumanReadableFileSize(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        double size = bytes;
        int unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:0.##} {units[unitIndex]}";
    }

    private sealed record ErrorGroupVm(string ErrorCode, string ErrorMessage, int Count);
}
