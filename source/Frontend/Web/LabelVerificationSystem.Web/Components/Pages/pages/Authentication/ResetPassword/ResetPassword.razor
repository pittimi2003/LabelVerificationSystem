@page "/reset-password"
@using MudBlazor
@layout Components.Layout.CustomLayout
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager
@inject LabelVerificationSystem.Web.Components.Auth.AuthApiClient AuthApiClient

        <div class="authentication bg-white authentication-cover-main mx-0">
            <MudGrid Spacing="0" class="auth-grid">
                <MudItem xs="12" sm="12" md="12"  lg="9"  xl="9">
                    <MudGrid class="justify-center align-center h-100">
                        <MudItem xs="12" sm="8" md="6" lg="5" xl="4">
                            <MudCard class="custom-card border-0 shadow-none my-4">
                                <MudCardContent class="pa-12">
                                    <div class="mb-4">
                                        <MudText Typo="Typo.h4" class="mb-1 fw-semibold">Reset Password</MudText>
                                        <MudText class="text-muted fw-normal">
                                            Solicita tu token de recuperación y luego confirma la nueva contraseña.
                                        </MudText>
                                    </div>

                                    <MudGrid class="gy-3">
                                        <MudItem xs="12">
                                            <label for="reset-identifier" class="form-label text-default">Username or Email</label>
                                            <MudTextField
                                                @bind-Value="UsernameOrEmail"
                                                Underline="false"
                                                Class="form-control form-control-lg"
                                                Variant="Variant.Text"
                                                Placeholder="you@example.com o username" />
                                        </MudItem>
                                    </MudGrid>

                                    <div class="d-grid mt-3">
                                        <MudButton Variant="Variant.Filled"
                                                   Class="mud-fixed-white-text"
                                                   Color="Color.Primary"
                                                   Disabled="@IsRequestingReset"
                                                   OnClick="RequestResetAsync">
                                            @(IsRequestingReset ? "Sending..." : "Request Reset Token")
                                        </MudButton>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(RequestMessage))
                                    {
                                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                                            @RequestMessage
                                        </MudAlert>
                                    }

                                    <MudDivider Class="my-4" />

                                    <MudGrid class="gy-3">
                                        <MudItem xs="12">
                                            <label for="reset-token" class="form-label text-default">Reset Token</label>
                                            <MudTextField
                                                @bind-Value="ResetToken"
                                                Underline="false"
                                                Class="form-control form-control-lg"
                                                Variant="Variant.Text"
                                                Placeholder="Pega aquí el token recibido" />
                                        </MudItem>
                                        <MudItem xs="12" sm="12" md="12" lg="12" xl="12">
                                            <label for="reset-newpassword" class="form-label text-default">New Password</label>
                                            <div class="position-relative">
                                                <MudTextField 
                                                    @bind-Value="Password2" 
                                                    Label="" 
                                                    Underline="false" 
                                                    Class="form-control form-control-lg"
                                                    Variant="Variant.Text" 
                                                    InputType="@Password2Input" 
                                                    Adornment="Adornment.End" 
                                                    AdornmentIcon="@Password2InputIcon" 
                                                    OnAdornmentClick="TogglePassword2Visibility" 
                                                    AdornmentAriaLabel="Show Password" Placeholder="New Password" />
                                            </div>
                                        </MudItem>
                                        <MudItem xs="12" sm="12" md="12" lg="12" xl="12">
                                            <label for="reset-confirmpassword" class="form-label text-default">Confirm
                                                Password</label>
                                            <div class="position-relative">
                                                <MudTextField 
                                                    @bind-Value="Password3" 
                                                    Label="" 
                                                    Underline="false" 
                                                    Class="form-control form-control-lg"
                                                    Variant="Variant.Text" 
                                                    InputType="@Password3Input" 
                                                    Adornment="Adornment.End" 
                                                    AdornmentIcon="@Password3InputIcon" 
                                                    OnAdornmentClick="TogglePassword3Visibility" 
                                                    AdornmentAriaLabel="Show Confirm Password" Placeholder="Confirm Password" />
                                            </div>
                                        </MudItem>
                                    </MudGrid>
                                    <div class="d-grid mt-3">
                                        <MudButton Variant="Variant.Filled"
                                                   Class="mud-fixed-white-text"
                                                   Color="Color.Primary"
                                                   Disabled="@IsConfirmingReset"
                                                   OnClick="ConfirmResetAsync">
                                            @(IsConfirmingReset ? "Saving..." : "Reset Password")
                                        </MudButton>
                                    </div>                                    
                                    @if (!string.IsNullOrWhiteSpace(ConfirmMessage))
                                    {
                                        <MudAlert Severity="@ConfirmSeverity" Dense="true" Class="mt-3">
                                            @ConfirmMessage
                                        </MudAlert>
                                    }
                                    <div class="text-center mt-3 fw-medium">
                                        Dont want to reset? <MudLink Href="/signin" class="mud-primary-text">Sign in Here</MudLink>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </MudItem>
                <MudItem xs="12" sm="12" md="12" lg="3"  xl="3" class="d-lg-block d-none px-0">
                    <div class="authentication-cover overflow-hidden">
                        <div class="authentication-cover-logo">
                        <MudLink Href="/index">
                            <MudImage Src="../assets/images/brand-logos/toggle-logo.png" alt="" class="desktop-dark" /> 
                        </MudLink>
                        </div>
                        <div class="authentication-cover-background">
                            <MudImage Src="../assets/images/media/backgrounds/9.png" alt="" /> 
                        </div>
                        <div class="authentication-cover-content relative z-10">
                            <div class="pa-15">
                                <MudText Typo="Typo.h3" class="fw-semibold lh-base mb-2">Welcome to Dashboard</MudText>
                                <MudText class="mb-0 text-muted fw-medium">Manage your website and content with ease using our powerful admin tools.</MudText>
                            </div>
                            <div>
                                <MudImage Src="../assets/images/media/media-72.png" alt="" class="img-fluid" /> 
                            </div>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

@code{

    public string? UsernameOrEmail { get; set; }
    public string? ResetToken { get; set; }
    public string? Password2 { get; set; }
    public string? Password3 { get; set; }
    public string? RequestMessage { get; set; }
    public string? ConfirmMessage { get; set; }
    public Severity ConfirmSeverity { get; set; } = Severity.Info;
    public bool IsRequestingReset { get; set; }
    public bool IsConfirmingReset { get; set; }

    bool isShowPassword2;
    InputType Password2Input = InputType.Password;
    string Password2InputIcon = "ri-eye-off-line fs-14 mb-1";

    bool isShowPassword3;
    InputType Password3Input = InputType.Password;
    string Password3InputIcon = "ri-eye-off-line fs-14 mb-1";

    void TogglePassword2Visibility()
    {
        if (isShowPassword2)
        {
            isShowPassword2 = false;
            Password2InputIcon = "ri-eye-off-line fs-14 mb-1";
            Password2Input = InputType.Password;
        }
        else
        {
            isShowPassword2 = true;
            Password2InputIcon = "ri-eye-line fs-14 mb-1";
            Password2Input = InputType.Text;
        }
    }
    void TogglePassword3Visibility()
    {
        if (isShowPassword3)
        {
            isShowPassword3 = false;
            Password3InputIcon = "ri-eye-off-line fs-14 mb-1";
            Password3Input = InputType.Password;
        }
        else
        {
            isShowPassword3 = true;
            Password3InputIcon = "ri-eye-line fs-14 mb-1";
            Password3Input = InputType.Text;
        }
    }
    async Task RequestResetAsync()
    {
        RequestMessage = null;
        ConfirmMessage = null;
        IsRequestingReset = true;

        try
        {
            var response = await AuthApiClient.RequestPasswordResetAsync(UsernameOrEmail?.Trim() ?? string.Empty, CancellationToken.None);
            RequestMessage = $"{response.Message} (En esta fase, entrega fuera de banda).";
        }
        catch (HttpRequestException ex)
        {
            RequestMessage = ex.Message;
        }
        finally
        {
            IsRequestingReset = false;
        }
    }

    async Task ConfirmResetAsync()
    {
        ConfirmMessage = null;
        IsConfirmingReset = true;

        try
        {
            await AuthApiClient.ConfirmPasswordResetAsync(
                ResetToken?.Trim() ?? string.Empty,
                Password2 ?? string.Empty,
                Password3 ?? string.Empty,
                CancellationToken.None);

            ConfirmSeverity = Severity.Success;
            ConfirmMessage = "Contraseña actualizada. Inicia sesión con la nueva contraseña.";
            ResetToken = null;
            Password2 = null;
            Password3 = null;
        }
        catch (HttpRequestException ex)
        {
            ConfirmSeverity = Severity.Error;
            ConfirmMessage = ex.Message;
        }
        finally
        {
            IsConfirmingReset = false;
        }
    }


}
