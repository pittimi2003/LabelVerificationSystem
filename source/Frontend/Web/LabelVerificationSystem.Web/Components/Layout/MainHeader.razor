                                            </div>
                                        </MudMenuItem>
                                        <MudMenuItem class="dropdown-item border-b position-relative">
                                            <a href="javascript:void(0);" class="stretched-link"></a>
                                            <div class="d-flex align-start gap-3">
                                                <div class="lh-1">
                                                    <MudAvatar class="mud-primary-transparent fs-5" Size="Size.Small">
                                                        <MudIcon Icon="ri-notification-line fs-16" />
                                                    </MudAvatar>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <span class="d-block fw-semibold">Event Reminder</span>
                                                    <span class="d-block text-muted fs-13">You have an upcoming event: Team Meeting on October 25 at 10 AM.</span>
                                                </div>
