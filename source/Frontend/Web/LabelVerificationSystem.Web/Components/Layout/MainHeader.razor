                                                <div class="lh-1">
                                                    <MudAvatar Class="bg-primary-transparent" Size="Size.Small">
                                                        <MudImage Src="../assets/images/faces/12.jpg" Alt="img"></MudImage>
                                                    </MudAvatar>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <span class="d-block fw-semibold">Friend Request</span>
