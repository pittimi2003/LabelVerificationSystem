                                                    <span class="d-block mb-1 fs-12 text-muted">12:58pm</span>
                                                    <span class="d-block mud-primary-text"><MudIcon Icon="ri-circle-fill fs-9 align-center" /></span>
                                                </div>
                                            </div>
                                        </MudMenuItem>
                                        <MudMenuItem class="dropdown-item position-relative">
                                            <a href="javascript:void(0);" class="stretched-link"></a>
                                            <div class="d-flex align-start gap-3">
                                                <div class="lh-1">
                                                    <MudAvatar class="mud-primary-transparent fs-5" Size="Size.Small">
                                                        <MudIcon Icon="ri-notification-line fs-16" />
                                                    </MudAvatar>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <span class="d-block fw-semibold">File Uploaded</span>
                                                    <span class="d-block text-muted fs-13">The file "Project_Proposal.pdf" has been uploaded successfully</span>
                                                </div>
                                                <div class="text-end">
                                                    <span class="d-block mb-1 fs-12 text-muted">05:13pm</span>
                                                    <span class="d-block mud-primary-text"><MudIcon Icon="ri-circle-fill fs-9 align-center" /></span>
