

@inject StateService stateService
@inject IActionService ActionService
@inject IJSRuntime JSRuntime
@inject IJSRuntime JS
@using Microsoft.JSInterop;
@using BlazorColorPicker
@inject IColorPickerService ColorPickerService
@using MudBlazor

    <header class="app-header sticky @headerClass" id="header">

        <!-- Start::main-header-container -->
        <div class="main-header-container container-fluid">

            <!-- Start::header-content-left -->
            <div class="header-content-left">

                <!-- Start::header-element -->
                <div class="header-element">
                    <div class="horizontal-logo">
                        <MudLink Href="" Class="header-logo">
                            <MudImage Src="../assets/images/brand-logos/desktop-logo.png" Alt="logo" Class="desktop-logo" />
                            <MudImage Src="../assets/images/brand-logos/toggle-logo.png" Alt="logo" Class="toggle-logo" />
                            <MudImage Src="../assets/images/brand-logos/desktop-dark.png" Alt="logo" Class="desktop-dark" />
                            <MudImage Src="../assets/images/brand-logos/toggle-dark.png" Alt="logo" Class="toggle-dark" />
                        </MudLink>
                    </div>
                </div>
                <!-- End::header-element -->

                <!-- Start::header-element -->
                <div class="header-element">
                    <!-- Start::header-link -->
                    <MudLink aria-label="Hide Sidebar" @onclick="ToggleMenu" Class="sidemenu-toggle header-link animated-arrow hor-toggle horizontal-navtoggle" Underline="Underline.None" Href="javascript:void(0);"><span></span></MudLink>
                    <!-- End::header-link -->
                </div>
                <!-- End::header-element -->

                <div Class="header-element  header-search header-search-content d-md-block d-none">
                    <!-- Start::header-link -->
                    <MudInput Value="@("")" Placeholder="Search" Underline="false" Class="header-search-bar form-control" id="header-search" Variant="Variant.Text" />
                    <MudLink Href="javascript:void(0);" Class="header-search-icon border-0">
                        <MudIcon Icon="bi bi-search fs-12 mb-2" />
                    </MudLink>
                    <!-- End::header-link -->
                </div>

            </div>
            <!-- End::header-content-left -->

            <!-- Start::header-content-right -->
            <div class="header-content-right">

                <!-- Start::header-element -->
                <li Class="header-element d-md-none d-flex">
                    <MudLink Href="javascript:void(0);" Class="header-link" OnClick="@(() => {OpenDialogFn(_dialogOptions, ref _visible1);})">
                        <!-- Start::header-link-icon -->
                        <svg xmlns="http://www.w3.org/2000/svg" Class="header-link-icon" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"/><circle cx="112" cy="112" r="80" opacity="0.2"/><circle cx="112" cy="112" r="80" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="168.57" y1="168.57" x2="224" y2="224" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
                        <!-- End::header-link-icon -->
                    </MudLink>  
                </li>
                <!-- End::header-element -->

                @* Start::header-element *@
                <div class="country-selector dropdown d-sm-block d-none">
                    <MudMenu Class="" Variant="Variant.Text"  PopoverClass="header-menu-dropdown-position country-dropdown-menu dropdown-menu" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent>
                            <MudLink Href="javascript:void(0);" Class="header-link dropdown-toggle" data-bs-auto-close="outside" data-bs-toggle="dropdown">
                                <svg xmlns="http://www.w3.org/2000/svg" Class="header-link-icon" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"/><path d="M215,168.71a96.42,96.42,0,0,1-30.54,37l-9.36-9.37a8,8,0,0,0-3.63-2.09L150,188.59a8,8,0,0,1-5.88-8.9l2.38-16.2a8,8,0,0,1,4.85-6.22l30.45-12.66a8,8,0,0,1,8.47,1.49Z" opacity="0.2"/><path d="M184,74a8,8,0,0,1-1.94,5.22L159.89,105a8,8,0,0,1-5,2.71l-31.46,4.26a8.06,8.06,0,0,1-5.77-1.45l-19.81-13a8,8,0,0,0-11.34,2l-20.94,31.3a8.06,8.06,0,0,0-1.35,4.41L64,171.49a8,8,0,0,1-3.61,6.64l-9.92,6.52A96,96,0,0,1,184,50Z" opacity="0.2"/><circle cx="128" cy="128" r="96" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M184.42,205.68l-9.36-9.37a8,8,0,0,0-3.63-2.09L150,188.59a8,8,0,0,1-5.88-8.9l2.38-16.2a8,8,0,0,1,4.85-6.22l30.45-12.66a8,8,0,0,1,8.47,1.49L215,168.71" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M50.49,184.65l9.92-6.52A8,8,0,0,0,64,171.49l.21-36.23a8.06,8.06,0,0,1,1.35-4.41l20.94-31.3a8,8,0,0,1,11.34-2l19.81,13a8.06,8.06,0,0,0,5.77,1.45l31.46-4.26a8,8,0,0,0,5-2.71L182.06,79.2A8,8,0,0,0,184,74V50" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
                            </MudLink>
                        </ActivatorContent>
                        <ChildContent>
                        
                            <MudMenuItem Class="border-b" Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/us_flag.jpg"></MudImage>
                                </MudAvatar>
                                English
                            </MudMenuItem>
                            <MudMenuItem Class="border-b" Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/spain_flag.jpg"></MudImage>
                                </MudAvatar>
                                español
                            </MudMenuItem>
                            <MudMenuItem Class="border-b" Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/french_flag.jpg"></MudImage>
                                </MudAvatar>
                                français
                            </MudMenuItem>
                            <MudMenuItem Class="border-b" Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/uae_flag.jpg"></MudImage>
                                </MudAvatar>
                                عربي
                            </MudMenuItem>
                            <MudMenuItem Class="border-b" Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/germany_flag.jpg"></MudImage>
                                </MudAvatar>
                                Deutsch
                            </MudMenuItem>
                            <MudMenuItem Class="border-b" Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/china_flag.jpg"></MudImage>
                                </MudAvatar>
                                中国人
                            </MudMenuItem>
                            <MudMenuItem Class="border-b" Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/italy_flag.jpg"></MudImage>
                                </MudAvatar>
                                Italiano
                            </MudMenuItem>
                            <MudMenuItem Href="javascript:void(0);">
                                <MudAvatar Class="mud-avatar-xs lh-1 me-2">
                                    <MudImage Src="../assets/images/flags/russia_flag.jpg"></MudImage>
                                </MudAvatar>
                                Русский
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </div>  
                @* End::header-element *@

                <!-- Start::header-element -->
                <li Class="header-element header-theme-mode"  @onclick='() => colorthemeFn()'>
                    <!-- Start::header-link|layout-setting -->
                    <MudLink Href="javascript:void(0);" Class="header-link layout-setting">
                        <span Class="light-layout">
                            <!-- Start::header-link-icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" Class="header-link-icon" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"/><path d="M108.11,28.11A96.09,96.09,0,0,0,227.89,147.89,96,96,0,1,1,108.11,28.11Z" opacity="0.2"/><path d="M108.11,28.11A96.09,96.09,0,0,0,227.89,147.89,96,96,0,1,1,108.11,28.11Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
                            <!-- End::header-link-icon -->
                        </span>
                        <span Class="dark-layout">
                            <!-- Start::header-link-icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" Class="header-link-icon" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"/><circle cx="128" cy="128" r="56" opacity="0.2"/><line x1="128" y1="40" x2="128" y2="32" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><circle cx="128" cy="128" r="56" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="64" y1="64" x2="56" y2="56" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="64" y1="192" x2="56" y2="200" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="192" y1="64" x2="200" y2="56" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="192" y1="192" x2="200" y2="200" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="40" y1="128" x2="32" y2="128" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="128" y1="216" x2="128" y2="224" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="216" y1="128" x2="224" y2="128" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
                            <!-- End::header-link-icon -->
                        </span>
                    </MudLink>
                    <!-- End::header-link|layout-setting -->
                </li>
                <!-- End::header-element -->

                @* Start::header-element *@
                <div class="header-element dropdown cart-dropdown">
                    <MudMenu Class="" Variant="Variant.Text" PopoverClass="header-menu-dropdown-position cart-dropdown-menu" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent>
                            <!-- Cart Icon with Dynamic Badge -->
                            <MudBadge Class="header-link dropdown-toggle" 
                                    Content="@CartCount" 
                                    Color="Color.Primary" 
                                    Overlap="true" 
                                    id="cart-icon-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" class="header-link-icon" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"></rect><path d="M70.55,144H196.1a16,16,0,0,0,15.74-13.14L224,64H56Z" opacity="0.2"></path><path d="M188,184H91.17a16,16,0,0,1-15.74-13.14L48.73,24H24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"></path><circle cx="92" cy="204" r="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"></circle><circle cx="188" cy="204" r="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"></circle><path d="M70.55,144H196.1a16,16,0,0,0,15.74-13.14L224,64H56" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"></path></svg>
                               
                            </MudBadge>
                        </ActivatorContent>

                        <ChildContent>
                            <!-- Cart Header -->
                            <MudMenuItem Class="dropdown-item pa-0 cart-menu-main-header rounded-t">
                                <div class="pa-4 mud-primary mud-fixed-white-text">
                                    <div class="d-flex align-center justify-space-between">
                                        <MudText Class="mb-0 fs-16 normal-badge">
                                            Cart Items
                                            <MudBadge Class="ms-1 fs-12 badge-pill" Color="Color.Warning" Content="@CartCount"></MudBadge>
                                        </MudText>
                                        <MudLink Href="javascript:void(0);" Class="mud-fixed-white-text text-decoration-underline fs-12">
                                            Continue Shopping
                                            <MudIcon Icon="ti ti-arrow-narrow-right fs-12 align-center" />
                                        </MudLink>
                                    </div>
                                </div>
                            </MudMenuItem>
                             
                             <BlazorOverlayScrollbars>
                                <BlazorOverlayScrollbarsContent>
                                 <div class="cart-list-menu">
                                    @if (CartItems.Any())
                                    {
                                        <!-- Looping Through Cart Items -->
                                        @foreach (var item in CartItems)
                                        {
                                            <MudMenuItem Class="dropdown-item border-b cart-menu-item" AutoClose=false>
                                                <div class="d-flex align-start cart-dropdown-item gap-3">
                                                    <MudAvatar Class="mud-avatar-xl bg-gray-300" Rounded="true">
                                                        <MudImage Src="@item.Image" Alt="@item.Title" />
                                                    </MudAvatar>

                                                    <div class="flex-grow-1 w-75">
                                                        <div class="d-flex align-start justify-space-between mb-3">
                                                            <div class="fs-14 fw-medium w-75">
                                                                <div class="text-truncate">
                                                                    <MudLink Href="javascript:void(0);" Class="mud-dark-text fw-semibold">@item.Title</MudLink>
                                                                </div>
                                                                <div class="fs-11 text-muted text-truncate">
                                                                    <span>@item.Description</span>
                                                                </div>
                                                            </div>

                                                            <!-- Delete Icon -->
                                                            <div class="text-end">
                                                                <MudLink href="javascript:void(0);" OnClick="() => DeleteItem(item)" class="header-cart-remove float-end dropdown-item-close">
                                                                    <MudIcon Icon="ri-delete-bin-line" class="fs-14 align-center text-muted" />
                                                                </MudLink>
                                                            </div>
                                                        </div>

                                                        <div class="d-flex align-center justify-space-between">
                                                            <div class="flex-grow-1">
                                                                <div class="lh-1 fs-12 mb-1">
                                                                    <span class="text-muted fw-normal d-inline-block text-decoration-line-through">
                                                                        @item.OldPrice
                                                                    </span>
                                                                    <span class="mud-success-text ms-1">@item.Offer</span>
                                                                </div>
                                                                <MudText Typo="Typo.h6" class="fw-medium mb-0">@item.Price</MudText>
                                                            </div>

                                                            <div class="d-flex rounded align-center flex-nowrap order-qnt gap-2 justify-end">
                                                                <MudLink href="javascript:void(0);" OnClick="() => DecreaseQty(item)" class="border px-1 rounded">
                                                                    <MudIcon Icon="ri-subtract-line" class="fs-14 align-center text-muted" />
                                                                </MudLink>
                                                                    <MudText>@item.Quantity</MudText>
                                                                <MudLink href="javascript:void(0);" OnClick="() => IncreaseQty(item)" class="border px-1 rounded">
                                                                    <MudIcon Icon="ri-add-line" class="fs-14 align-center text-muted" />
                                                                </MudLink>
                                                            </div>

                                                        </div>
                                                    </div>
                                                </div>
                                            </MudMenuItem>
                                        }
                                    }
                                        else
                                    {
                                        <div class="pa-5 empty-item">
                                            <div class="text-center">
                                                <MudAvatar class="mud-avatar-xl avatar-rounded mud-success-transparent">
                                                    <MudIcon Icon="ti ti-shopping-cart fs-2" />
                                                </MudAvatar>
                                                <MudText Typo="Typo.h6" class="fw-medium mb-1 mt-3">No items in your cart yet</MudText>
                                                <span class="mb-3 fw-normal fs-13 d-block">Add some to enjoy a seamless checkout experience! :)</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                             </BlazorOverlayScrollbarsContent>
                            </BlazorOverlayScrollbars>

                            <!-- Footer -->
                            <div AutoClose=false class="dropdown-item cart-menu-item @(CartItems.Any() ? "" : "d-none")">
                                <div class="pa-4 empty-header-item1 border-t">
                                    <div class="text-center d-grid">
                                        <MudButton Variant="Variant.Filled" Href="checkout" Color="Color.Primary"  FullWidth="true">Proceed to checkout</MudButton>
                                    </div>
                                </div>
                            </div>
                        </ChildContent>
                    </MudMenu>
                </div>
                @* End::header-element *@
                
                @* Start::header-element *@
                <div class="header-element dropdown notifications-dropdown">
                    <MudMenu Class="" Variant="Variant.Text"  PopoverClass="header-menu-dropdown-position notification-dropdown-menu" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent>
                            <!-- Start::header-link|dropdown-toggle -->
                            <MudLink Href="javascript:void(0);" Class="header-link dropdown-toggle" data-bs-toggle="dropdown" data-bs-auto-close="outside" id="messageDropdown" aria-expanded="false">
                                <svg xmlns="http://www.w3.org/2000/svg" Class="header-link-icon" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"/><path d="M56,104a72,72,0,0,1,144,0c0,35.82,8.3,64.6,14.9,76A8,8,0,0,1,208,192H48a8,8,0,0,1-6.88-12C47.71,168.6,56,139.81,56,104Z" opacity="0.2"/><path d="M96,192a32,32,0,0,0,64,0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M56,104a72,72,0,0,1,144,0c0,35.82,8.3,64.6,14.9,76A8,8,0,0,1,208,192H48a8,8,0,0,1-6.88-12C47.71,168.6,56,139.81,56,104Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
                                <span Class="header-icon-pulse mud-theme-secondary rounded pulse pulse-secondary"></span>
                            </MudLink>
                            <!-- End::header-link|dropdown-toggle -->
                        </ActivatorContent>
                        <ChildContent> 
